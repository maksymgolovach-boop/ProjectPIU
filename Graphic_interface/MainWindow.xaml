<Window x:Class="Graphic_interface.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Graphic_interface"
        mc:Ignorable="d"
        Title="Orarul personal" Height="550" Width="800" Background="white"
        WindowStyle="SingleBorderWindow">

 

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="250"/>
        </Grid.ColumnDefinitions>

        <!-- PANELUL LISTEI DE ACTIVITATI -->
            <Grid Grid.Column="0"
                    Background="#f5f4ed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

            <Label Content="ACTIVITATI" Foreground="#7a7872"
                   HorizontalAlignment="left"
                   FontFamily="Bahnschrift Light"
                   Margin="5 5 0 5"
                   FontSize="20"
                   Grid.Row="0"/>

            <!-- LISTA DE ACTIVITATI -->
                <WrapPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="5 0 5 0">
                <ListView x:Name="ActivityListView"
                              VirtualizingPanel.ScrollUnit="Pixel"
                              Background="Transparent"
                              BorderThickness = "0">
                    <ListView.ItemTemplate>
                            <DataTemplate>
                            <Border Background="White" CornerRadius="12" Margin="0,10,0,10" Padding="15" Width="180">
                                <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                    

                                    <TextBlock Grid.Row="0"
                                                   Foreground="Black"
                                                   FontFamily="Inter 18pt"
                                                   Text="{Binding name}" 
                                                   FontSize="14" 
                                                   FontWeight="Bold" 
                                                   Margin="0,0,0,5" />

                                        <Rectangle Grid.Row="1" Fill="#7a7872" Height="1" Margin="0,0,0,10"/>

                                        <TextBlock Grid.Row="2"
                                                   Foreground="{Binding type, Converter={StaticResource TypeToColor}}"
                                                   FontFamily="Bahnschrift Light"
                                                   Text="{Binding TipulStr}"
                                                   FontSize="11"
                                                   TextWrapping="Wrap" />   
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </WrapPanel>

                <StackPanel Grid.Row="2" Orientation="Vertical">
                    <Button Content="+ Noua activitate" Style="{StaticResource DashedButtonStyle}" Margin="10" Click="AddActivityWindow"/>
                    <Label Content="LEGENDA"
                           Margin="5"/>
                    
                    <ScrollViewer  MaxHeight="100" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="TypesLegend" Margin="15 0 0 0 ">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">

                                        <Ellipse Width="12" Height="12" 
                                 Fill="{Binding Type, Converter={StaticResource TypeToColor}}" 
                                 VerticalAlignment="Center" />

                                        <TextBlock Text="{Binding DisplayName}" 
                                       Foreground="#333333" 
                                       FontSize="14" 
                                       Margin="12,0,0,0" 
                                       VerticalAlignment="Center" />

                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
            </StackPanel>
                
            </Grid>
        
        
        <Rectangle Width="1" Fill="#dedddd" HorizontalAlignment="Right"/>
        <!-- REGIUNEA CALENDAR O SA SE DEZVOLTE IN CURAND -->
        <StackPanel Grid.Column="1">
            
        </StackPanel>

        <StackPanel Grid.Column="2"
                    Background="#f5f4ed">
            <Label Content="Deadlines" Foreground="#7a7872"
                   HorizontalAlignment="left"
                   FontFamily="Bahnschrift Light"
                   Margin="0 5"
                   FontSize="20"/>
            
        </StackPanel>

    </Grid>
</Window>
